<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0" jcr:primaryType="cq:Page">
  <jcr:content cq:template="/libs/core/franklin/templates/page" sling:resourceType="core/franklin/components/page/v1/page" jcr:primaryType="cq:PageContent" jcr:title="The Last Printer You'll Ever Need">
    <root jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/root/v1/root">
      <section sling:resourceType="core/franklin/components/section/v1/section" jcr:primaryType="nt:unstructured" model="section" modelFields="[name,style]">
        <block sling:resourceType="core/franklin/components/block/v1/block" jcr:primaryType="nt:unstructured" image="/content/dam/ema-hp-forms/heroes/hp-smarttank-hero.png" imageAlt="HP Smart Tank printer with colorful prints" model="hero" modelFields="[image,imageAlt,text]" name="Hero" text="&lt;h1&gt;The Last Printer You'll Ever Need&lt;/h1&gt;&lt;p&gt;HP Smart Tank refillable, cartridge-free ink tank printers deliver reliable, low-cost, high-volume printing that lasts for years.&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;https://www.hp.com/us-en/shop/cat/printers&quot;&gt;Shop Smart Tank&lt;/a&gt;&lt;/p&gt;"/>
      </section>
      <section_1 sling:resourceType="core/franklin/components/section/v1/section" jcr:primaryType="nt:unstructured" model="section" modelFields="[name,style]">
        <title sling:resourceType="core/franklin/components/title/v1/title" jcr:primaryType="nt:unstructured" title="Why HP Smart Tank?" titleType="h2"/>
        <block sling:resourceType="core/franklin/components/block/v1/block" jcr:primaryType="nt:unstructured" filter="cards" name="Cards">
          <item_0 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" name="Card" model="card" modelFields="[image,text]" image="/content/dam/ema-hp-forms/categories/hp-smarttank-5101.png" text="&lt;p&gt;&lt;strong&gt;Up to 3 Years of Vibrant Ink Included&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Print up to 6,000 black / 8,000 color pages right out of the box.&lt;/p&gt;"/>
          <item_1 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" name="Card" model="card" modelFields="[image,text]" image="/content/dam/ema-hp-forms/categories/hp-smarttank-5401.png" text="&lt;p&gt;&lt;strong&gt;Best Print Quality&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Sharper text. Richer colors. 31% higher average print quality rating than competitors.&lt;/p&gt;"/>
          <item_2 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" name="Card" model="card" modelFields="[image,text]" image="/content/dam/ema-hp-forms/categories/hp-smarttank-7602.png" text="&lt;p&gt;&lt;strong&gt;Easiest-to-Use Tank Printer&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Set up once and print with confidence. No complex maintenance.&lt;/p&gt;"/>
          <item_3 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" name="Card" model="card" modelFields="[image,text]" image="/content/dam/ema-hp-forms/categories/hp-smarttank-7602.png" text="&lt;p&gt;&lt;strong&gt;Cartridge-free&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Print longer with fewer interruptions.&lt;/p&gt;"/>
        </block>
      </section_1>
      <section_2 sling:resourceType="core/franklin/components/section/v1/section" jcr:primaryType="nt:unstructured" style="[light]" model="section" modelFields="[name,style]">
        <title sling:resourceType="core/franklin/components/title/v1/title" jcr:primaryType="nt:unstructured" title="Compare Smart Tanks" titleType="h2"/>
        <block sling:resourceType="core/franklin/components/block/v1/block" jcr:primaryType="nt:unstructured" name="Feature Grid" model="feature-grid" modelFields="[image,imageAlt,title,specs,cta,ctaText]">
          <item_0 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" image="/content/dam/ema-hp-forms/categories/hp-smarttank-5101.png" imageAlt="HP Smart Tank 5000/5100 Series" title="Smart Tank 5000/5100 Series" specs="&lt;p&gt;&lt;strong&gt;Best For Affordable Everyday Prints&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;6,000 black / 6,000 color pages&lt;/li&gt;&lt;li&gt;12 black / 5 color pages per minute&lt;/li&gt;&lt;li&gt;Wireless&lt;/li&gt;&lt;li&gt;Manual 2-sided&lt;/li&gt;&lt;li&gt;Flatbed scanner&lt;/li&gt;&lt;/ul&gt;" ctaText="Shop" cta="https://www.hp.com/us-en/shop/cat/printers"/>
          <item_1 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" image="/content/dam/ema-hp-forms/categories/hp-smarttank-5401.png" imageAlt="HP Smart Tank 6000 Series" title="Smart Tank 6000 Series" specs="&lt;p&gt;&lt;strong&gt;Best for Creative and Everyday Prints&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;6,000 black / 8,000 color pages&lt;/li&gt;&lt;li&gt;12 black / 7 color pages per minute&lt;/li&gt;&lt;li&gt;Wireless dual-band Wi-Fi&lt;/li&gt;&lt;li&gt;Automatic 2-sided&lt;/li&gt;&lt;li&gt;Flatbed scanner&lt;/li&gt;&lt;/ul&gt;" ctaText="Shop" cta="https://www.hp.com/us-en/shop/cat/printers"/>
          <item_2 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" image="/content/dam/ema-hp-forms/categories/hp-smarttank-7602.png" imageAlt="HP Smart Tank 7600 Series" title="Smart Tank 7600 Series" specs="&lt;p&gt;&lt;strong&gt;Best For Home And Work Productivity&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;6,000 black / 8,000 color pages&lt;/li&gt;&lt;li&gt;15 black / 9 color pages per minute&lt;/li&gt;&lt;li&gt;Wireless dual-band Wi-Fi&lt;/li&gt;&lt;li&gt;Automatic 2-sided&lt;/li&gt;&lt;li&gt;35-page Auto Document Feeder&lt;/li&gt;&lt;li&gt;Fax capability&lt;/li&gt;&lt;/ul&gt;" ctaText="Shop" cta="https://www.hp.com/us-en/shop/cat/printers"/>
        </block>
      </section_2>
      <section_3 sling:resourceType="core/franklin/components/section/v1/section" jcr:primaryType="nt:unstructured" model="section" modelFields="[name,style]">
        <title sling:resourceType="core/franklin/components/title/v1/title" jcr:primaryType="nt:unstructured" title="Key Features" titleType="h2"/>
        <block sling:resourceType="core/franklin/components/block/v1/block" jcr:primaryType="nt:unstructured" name="Steps" model="steps" modelFields="[title,description]">
          <item_0 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" title="Easiest-to-Use Tank Printer" description="&lt;p&gt;Fast setup, reliable Wi-Fi, intuitive controls, and smart-guided lighting.&lt;/p&gt;"/>
          <item_1 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" title="Mess-Free Refill" description="&lt;p&gt;Spill-free ink bottle system with simple refill process.&lt;/p&gt;"/>
          <item_2 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" title="Most Reliable Connectivity" description="&lt;p&gt;Dual-band Wi-Fi with self-healing network detection.&lt;/p&gt;"/>
          <item_3 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" title="Consistent Prints Over Time" description="&lt;p&gt;Updated black ink stays fresh for 12 weeks without printing.&lt;/p&gt;"/>
        </block>
      </section_3>
      <section_4 sling:resourceType="core/franklin/components/section/v1/section" jcr:primaryType="nt:unstructured" style="[highlight]" model="section" modelFields="[name,style]">
        <title sling:resourceType="core/franklin/components/title/v1/title" jcr:primaryType="nt:unstructured" title="Built For A Better Tomorrow" titleType="h2"/>
        <text sling:resourceType="core/franklin/components/text/v1/text" jcr:primaryType="nt:unstructured" text="&lt;p&gt;Sustainability is embedded in what we do — from how we innovate, to how we operate, to how we engage with our communities. It is not a separate initiative, but a core element of our strategy to grow responsibly and create lasting value for all our stakeholders.&lt;/p&gt;"/>
      </section_4>
